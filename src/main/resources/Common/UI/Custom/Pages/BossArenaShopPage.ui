Group {
  Anchor: (Left: 0, Top: 0, Width: 1920, Height: 1080);

  Panel #Overlay {
    Anchor: (Left: 0, Top: 0, Width: 1920, Height: 1080);
    Background: #000000(0.45);
  }

  Panel #Background {
    Anchor: (Left: 330, Top: 88, Width: 1260, Height: 904);
    Background: #0f1725;
  }

  Panel #AccentLeft {
    Anchor: (Left: 330, Top: 88, Width: 4, Height: 904);
    Background: #4f79ab;
  }

  Panel #HeaderPanel {
    Anchor: (Left: 334, Top: 88, Width: 1256, Height: 104);
    Background: #152238;
  }

  Label #TitleLabel {
    Anchor: (Left: 368, Top: 108, Width: 860, Height: 42);
    Text: "Boss Arena // Contract Board";
    Style: (FontSize: 31, TextColor: #f3f7ff, RenderBold: true);
  }

  Label #SubtitleLabel {
    Anchor: (Left: 368, Top: 150, Width: 880, Height: 26);
    Text: "Choose a tier and summon a boss.";
    Style: (FontSize: 15, TextColor: #b2c0d2);
  }

  TextButton #CloseButton {
    Anchor: (Left: 1428, Top: 116, Width: 136, Height: 48);
    Text: "Close";
    Style: TextButtonStyle(
      Default: (Background: #2a3d58, LabelStyle: (FontSize: 14, TextColor: #e6eefc, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #38567b, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #4d77a8, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Disabled: (Background: #253244, LabelStyle: (FontSize: 14, TextColor: #8ea1bb, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  Panel #TierPanel {
    Anchor: (Left: 360, Top: 214, Width: 1200, Height: 60);
    Background: #182a44;
  }

  Panel #TierBordercommon {
    Anchor: (Left: 606, Top: 220, Width: 234, Height: 48);
    Background: #8fb7ff;
    Visible: false;
  }

  Panel #TierBorderuncommon {
    Anchor: (Left: 369, Top: 220, Width: 234, Height: 48);
    Background: #8fb7ff;
    Visible: false;
  }

  Panel #TierBorderrare {
    Anchor: (Left: 843, Top: 220, Width: 234, Height: 48);
    Background: #8fb7ff;
    Visible: false;
  }

  Panel #TierBorderepic {
    Anchor: (Left: 1080, Top: 220, Width: 234, Height: 48);
    Background: #8fb7ff;
    Visible: false;
  }

  Panel #TierBorderlegendary {
    Anchor: (Left: 1317, Top: 220, Width: 234, Height: 48);
    Background: #8fb7ff;
    Visible: false;
  }

  TextButton #TierBtncommon {
    Anchor: (Left: 609, Top: 223, Width: 228, Height: 42);
    Text: "Common";
    Style: TextButtonStyle(
      Default: (Background: #2b4568, LabelStyle: (FontSize: 14, TextColor: #d8e3f4, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Hovered: (Background: #3f6391, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
      Pressed: (Background: #4f79ab, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
    );
  }

  TextButton #TierBtnuncommon {
    Anchor: (Left: 372, Top: 223, Width: 228, Height: 42);
