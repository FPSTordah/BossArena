  }

  Group #ItemCard1 {
    Anchor: (Left: 360, Top: 296, Width: 585, Height: 150);
    Background: #172639;

    ItemIcon #ItemIcon1 {
      Anchor: (Left: 22, Top: 46, Width: 56, Height: 56);
    }

    Label #ItemName1 {
      Anchor: (Left: 24, Top: 16, Width: 370, Height: 32);
      Text: "Contract Name";
      Style: (FontSize: 20, TextColor: #f3f7ff, RenderBold: true);
    }

    Label #ItemPrice1 {
      Anchor: (Left: 24, Top: 52, Width: 370, Height: 24);
      Text: "Price";
      Style: (FontSize: 15, TextColor: #ffd88f, RenderBold: true);
    }

    Label #ItemDesc1 {
      Anchor: (Left: 24, Top: 82, Width: 370, Height: 46);
      Text: "Description";
      Style: (FontSize: 13, TextColor: #b1bfd4);
    }

    TextButton #BuyBtn1 {
      Anchor: (Left: 416, Top: 52, Width: 150, Height: 46);
      Text: "Summon";
      Style: TextButtonStyle(
        Default: (Background: #1f7d4b, LabelStyle: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
        Hovered: (Background: #2b9a5f, LabelStyle: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
        Pressed: (Background: #17633c, LabelStyle: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
        Disabled: (Background: #334358, LabelStyle: (FontSize: 15, TextColor: #8ea0bb, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center))
      );
    }
  }

