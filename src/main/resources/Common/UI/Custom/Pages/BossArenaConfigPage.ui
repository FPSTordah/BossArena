    Group #BossEditorOverlay {
      Anchor: (Left: 0, Top: 0, Width: 1200, Height: 660);
      Visible: false;

      Panel #BossEditorBackdrop {
        Anchor: (Left: 0, Top: 0, Width: 1200, Height: 660);
        Background: #05090f(0.75);
      }

      Panel #BossEditorWindow {
        Anchor: (Left: 90, Top: 56, Width: 1020, Height: 548);
        Background: #0f1725;
      }

      Label #BossEditorTitle {
        Anchor: (Left: 118, Top: 78, Width: 760, Height: 30);
