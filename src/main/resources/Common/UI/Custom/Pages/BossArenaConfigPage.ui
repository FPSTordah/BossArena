  Group #ArenasPanel {
    Anchor: (Left: 360, Top: 296, Width: 1200, Height: 660);
    Visible: false;

    Label #ArenaTitleLabel {
      Anchor: (Left: 32, Top: 28, Width: 800, Height: 30);
