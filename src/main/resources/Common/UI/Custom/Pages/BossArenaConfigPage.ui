      TextField #BossEditName { Anchor: (Left: 118, Top: 140, Width: 155, Height: 28); Value: ""; Style: (FontSize: 13, TextColor: #e6eefc); Padding: (Left: 8); Background: #122036; }
      Label #BossEditNpcIdLabel { Anchor: (Left: 283, Top: 118, Width: 155, Height: 20); Text: "NPC ID"; Style: (FontSize: 13, TextColor: #8ea1bb, RenderBold: true); }
      TextField #BossEditNpcId { Anchor: (Left: 283, Top: 140, Width: 155, Height: 28); Value: ""; Style: (FontSize: 13, TextColor: #e6eefc); Padding: (Left: 8); Background: #122036; }
      Label #BossEditTierLabel { Anchor: (Left: 448, Top: 118, Width: 100, Height: 20); Text: "Tier"; Style: (FontSize: 13, TextColor: #8ea1bb, RenderBold: true); }
      TextField #BossEditTier { Anchor: (Left: 448, Top: 140, Width: 100, Height: 28); Value: "uncommon"; Style: (FontSize: 13, TextColor: #e6eefc); Padding: (Left: 8); Background: #122036; }
      Label #BossEditAmountLabel { Anchor: (Left: 558, Top: 118, Width: 100, Height: 20); Text: "Amount"; Style: (FontSize: 13, TextColor: #8ea1bb, RenderBold: true); }
      TextField #BossEditAmount { Anchor: (Left: 558, Top: 140, Width: 100, Height: 28); Value: "1"; Style: (FontSize: 13, TextColor: #e6eefc); Padding: (Left: 8); Background: #122036; }
      Label #BossEditLootRadiusLabel { Anchor: (Left: 668, Top: 118, Width: 100, Height: 20); Text: "Loot Radius"; Style: (FontSize: 13, TextColor: #8ea1bb, RenderBold: true); }
